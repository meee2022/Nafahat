EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Sentry crash reporting — auto-picked up by src/utils/logger.ts
# To activate:
#   1. Create free account on sentry.io
#   2. Make a React Native project
#   3. Copy your DSN here
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_DSN_HERE@oXXXXXX.ingest.sentry.io/XXXXX

# RevenueCat premium subscriptions — auto-picked up by src/services/premium.ts
# To activate:
#   1. Create account on revenuecat.com
#   2. Add iOS app + Android app
#   3. Copy SDK keys here
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=
